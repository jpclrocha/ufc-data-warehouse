    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here
var txt = NM_CATEGORIA_COMPLETA.toUpperCase();
var FIGHT_TYPE = "";

if (txt.indexOf("INTERIM") >= 0) {
  FIGHT_TYPE = "INTERIM TITLE";
} else if (txt.indexOf("TITLE") >= 0) {
  FIGHT_TYPE = "TITLE";
} else {
  FIGHT_TYPE = "NORMAL";
}</jsScript_script>
      </jsScript>
